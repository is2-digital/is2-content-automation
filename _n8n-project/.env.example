# ==================================================
# n8n Environment Configuration Template
# ==================================================
# Copy this file to .env and update the values
# Command: cp .env.example .env

# --------------------------------------------------
# TIMEZONE CONFIGURATION
# --------------------------------------------------
TIMEZONE=America/Los_Angeles

# --------------------------------------------------
# DATABASE CONFIGURATION
# --------------------------------------------------
# PostgreSQL root password - CHANGE THIS!
POSTGRES_PASSWORD=change_me_root_password_123

# n8n application database user password - CHANGE THIS!
N8N_APP_PASSWORD=change_me_app_password_456

# Custom data database user password - CHANGE THIS!
N8N_CUSTOM_DATA_PASSWORD=change_me_custom_data_password_789

# Optional: Database connection tuning
DB_POOL_SIZE=2

# --------------------------------------------------
# n8n BASIC CONFIGURATION
# --------------------------------------------------
# Domain for production (leave empty for local development)
N8N_DOMAIN=

# Protocol (http for local, https for production)
N8N_PROTOCOL=http

# --------------------------------------------------
# SECURITY CONFIGURATION
# --------------------------------------------------
# Basic Auth (recommended for production)
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_admin_password

# --------------------------------------------------
# PERFORMANCE & LOGGING
# --------------------------------------------------
# Log level: error, warn, info, verbose, debug
N8N_LOG_LEVEL=info

# Enable metrics endpoint
N8N_METRICS=false

# --------------------------------------------------
# PRIVACY SETTINGS
# --------------------------------------------------
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_ANONYMOUS_TELEMETRY=false

# --------------------------------------------------
# DEVELOPMENT SETTINGS
# --------------------------------------------------
# Enable detailed error messages (disable in production)
N8N_DETAILED_ERROR_OUTPUT=true