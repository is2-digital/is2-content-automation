# is2-content-automation (ica) — Environment Variables
# Copy this file to .env.dev, .env.stage, or .env.prod and fill in real values.
# See docs/credentials.md for details.

# --- PostgreSQL ---
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=n8n_custom_data
POSTGRES_USER=ica

# --- OpenRouter (LLM gateway) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# --- Slack (Bot + Socket Mode) ---
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL=C0000000000

# --- Google APIs ---
# Service account key: copy to credentials/google-service-account.json
# (see credentials/google-service-account.example.json for format)
# Shared Drive ID — all files are created here (service account has no own storage)
# Leave blank to auto-discover the first Shared Drive accessible to the service account
GOOGLE_SHARED_DRIVE_ID=

# Spreadsheet ID for article curation review (from the URL: /spreadsheets/d/<THIS_ID>/edit)
# The service account must have edit access (share the sheet with its email)
CURATED_ARTICLES_GOOGLE_SHEET_ID=

# --- Guided test targets (optional — only for `ica guided`) ---
# Override spreadsheet and Drive folder for guided test runs so production resources
# are not modified. Required when running `ica guided` with steps that use Google services.
# GUIDED_TEST_SPREADSHEET_ID=
# GUIDED_TEST_DRIVE_FOLDER_ID=

# --- Google Custom Search (deprecated — use Brave Search instead) ---
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# --- Brave Search ---
BRAVE_API_KEY=xxxxxxxxxxxxxxxxxxxx

# --- Email notifications (optional) ---
# Sends email alerts when pipeline errors occur.
# Uses Gmail SMTP with App Passwords (not your regular password).
# Generate an App Password: Google Account → Security → 2-Step Verification → App passwords
# Leave EMAIL_SMTP_USER blank to disable email notifications entirely.
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=you@gmail.com
# EMAIL_SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# EMAIL_FROM=you@gmail.com
# EMAIL_TO=you@gmail.com,teammate@gmail.com

# --- General ---
TIMEZONE=America/Los_Angeles
